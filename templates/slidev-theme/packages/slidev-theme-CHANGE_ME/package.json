{
  "name": "slidev-theme-CHANGE_ME",
  "type": "module",
  "version": "0.1.0",
  "description": "CHANGE_ME Slidev theme",
  "license": "MIT",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "slidev example.md --port ${PORT:-3030} --remote --bind 127.0.0.1",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@slidev/types": "^52.16.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/client": "^52.16.0",
    "playwright-chromium": "^1.61.1",
    "slidev-addon-CHANGE_ME": "workspace:*"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "light",
    "highlighter": "shiki",
    "defaults": {
      "fonts": {
        "sans": "Noto Sans JP",
        "mono": "Fira Code",
        "provider": "google"
      },
      "aspectRatio": "16/9",
      "canvasWidth": 1000
    }
  }
}
